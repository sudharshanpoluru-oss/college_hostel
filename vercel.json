{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://mysql-production-52ed2.up.railway.app/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://mysql-production-52ed2.up.railway.app/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
